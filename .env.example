# ── AI ─────────────────────────────────────────────────────────────────────────
# Required for /api/ai/seed and /api/ai/search.
GEMINI_API_KEY=your_gemini_api_key_here

# Optional — override the Gemini model used for AI features.
# GEMINI_MODEL=gemini-2.5-flash

# ── Database ────────────────────────────────────────────────────────────────────
# Optional — defaults to the Docker volume path used in production.
# DATABASE_URL=sqlite:////app/data/hardware.db

# ── Admin Bootstrap ─────────────────────────────────────────────────────────────
# On startup the backend checks these variables and ensures a first admin user
# exists.  The routine is idempotent — restarting the server with the same
# values is always safe.
#
# Set BOOTSTRAP_ADMIN_ENABLED=false to skip the routine entirely (e.g. in CI).
BOOTSTRAP_ADMIN_ENABLED=true
BOOTSTRAP_ADMIN_EMAIL=admin@company.com
BOOTSTRAP_ADMIN_PASSWORD=password
